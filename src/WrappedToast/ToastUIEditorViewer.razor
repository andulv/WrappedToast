@inherits ToastUIEditorCore

<div @ref="ElementRef" style="@InitialStyle"></div>

@code {
    protected override string JsModulePath => "./_content/WrappedToast/ToastUIEditorViewer.razor.js";

    /// <summary>Set the markdown body shown by the viewer.</summary>
    public async Task SetMarkdownAsync(string markdown)
    {
        await SetMarkdownCoreAsync(markdown);
    }

    /// <summary>Get the markdown body currently shown by the viewer. Transfered as stream from client to server.</summary>
    public async Task<string> GetMarkdownAsync()
    {
        return await InvokeStringStreamMethodAsync("getMarkdownAsBlob");
    }

    /// <summary>Get the current rendered HTML body from the viewer. Transfered as stream from client to server.</summary>
    public async Task<string> GetHtmlAsync()
    {
        return await InvokeStringStreamMethodAsync("getHTMLAsBlob");
    }

    /// <summary>Check whether the wrapped native component is a viewer.</summary>
    public async Task<bool> IsViewerAsync()
    {
        return await InvokeBoolMethodAsync("isViewer", true);
    }

    /// <summary>Check whether the viewer is in markdown mode.</summary>
    public async Task<bool> IsMarkdownModeAsync()
    {
        return await InvokeBoolMethodAsync("isMarkdownMode");
    }

    /// <summary>Check whether the viewer is in WYSIWYG mode.</summary>
    public async Task<bool> IsWysiwygModeAsync()
    {
        return await InvokeBoolMethodAsync("isWysiwygMode");
    }

    /// <summary>Unbind handlers for the given event type.</summary>
    public async Task OffAsync(string type)
    {
        await InvokeVoidMethodAsync("off", type);
    }

}
