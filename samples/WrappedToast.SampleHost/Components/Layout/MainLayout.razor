@implements IDisposable
@inherits LayoutComponentBase
@inject NavigationManager Navigation

<MudThemeProvider IsDarkMode="@_isDark" Theme="@_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="sample-layout d-flex flex-column">
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6">WrappedToast Sample Host - @CurrentPageTitle</MudText>
        <MudSpacer />
        <MudSwitch T="bool" @bind-Value="_isDark" Label="@(_isDark ? "Dark" : "Light")" Color="Color.Primary" />
    </MudAppBar>
    <MudDrawer id="nav-drawer" @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>
    <MudMainContent Class="pt-16 pa-4 d-flex flex-column flex-auto overflow-hidden" Style="min-height:0;">
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _isDark;
    private bool _drawerOpen = true;
    private readonly MudTheme _theme = new();

    private string CurrentPageTitle => GetPageTitle();

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private string GetPageTitle()
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/').ToLowerInvariant();

        return relativePath switch
        {
            "" => "Home",
            "dual-sample" => "Dual Sample",
            "editor-full-size" => "Full Height Editor",
            "viewer-full-size" => "Full Height Viewer",
            "split-full-size" => "Split Editor And Viewer",
            _ => "Sample Host"
        };
    }
}
