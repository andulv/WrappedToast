@page "/wrappedtoast-sample"
@inject IWebHostEnvironment Env
@using SampleHost.Components.Pages

<PageTitle>WrappedToast - WrappedToast Sample</PageTitle>

<div class="sample-min-height-0 d-flex flex-column flex-1 overflow-hidden mud-width-full">
    <MudPaper Class="pa-3 d-flex flex-column flex-1 overflow-hidden">
        <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3 flex-none wrappedtoast-sample-toolbar">
            <MudSelect T="string"
                       Label="Sample Document"
                       Value="_selectedSampleKey"
                       ValueChanged="OnSampleChanged"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Class="mud-width-full"
                       Style="max-width:360px;">
                @foreach (var option in _options)
                {
                    <MudSelectItem T="string" Value="@option.Key">@option.Name</MudSelectItem>
                }
            </MudSelect>

            <MudFileUpload T="IBrowserFile"
                           Accept=".md,text/markdown,text/plain"
                           Hidden="true"
                           DragAndDrop="true"
                           FilesChanged="OnUploadedMarkdownChanged"
                           Dragging="_isUploadDragging"
                           DraggingChanged="OnUploadDraggingChanged"
                           Class="wrappedtoast-sample-upload">
                <CustomContent>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               StartIcon="@(_isUploadDragging ? Icons.Material.Filled.FileDownload : Icons.Material.Filled.UploadFile)"
                               OnClick="context.OpenFilePickerAsync"
                               Class="@GetUploadButtonClass()">
                        Upload
                    </MudButton>
                </CustomContent>
                <SelectedTemplate />
            </MudFileUpload>
        </MudStack>

        <div class="sample-min-height-0 d-flex flex-column flex-1 overflow-hidden">
            <WrappedToast Title="@_wrappedTitle"
                          Content="@_wrappedContent"
                          OnSave="OnWrappedSaveAsync">
                <ToolbarExtras>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="ResetWrappedSample">
                        Reset sample
                    </MudButton>
                </ToolbarExtras>
            </WrappedToast>
        </div>

        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3 flex-none">
            Last saved (full markdown including front matter):
            <pre style="white-space:pre-wrap">@_lastSaved</pre>
        </MudAlert>
    </MudPaper>
</div>

@code {
    private const long MaxUploadedMarkdownBytes = 1_048_576;

    private IReadOnlyList<SampleOption> _options = [];
    private string _selectedSampleKey = SampleMarkdownContent.DefaultKey;
    private string _wrappedTitle = "sample.md";
    private string _wrappedContent = SampleMarkdownContent.BuiltInSamples[0].Markdown;
    private string _lastSaved = "(nothing saved yet)";
    private string _loadedTitle = "sample.md";
    private string _loadedContent = SampleMarkdownContent.BuiltInSamples[0].Markdown;
    private bool _isUploadDragging;

    protected override void OnInitialized()
    {
        _options = SampleMarkdownContent.BuildSampleOptions(Env.ContentRootPath);
        SyncLoadedDocument(_wrappedTitle, _wrappedContent);
    }

    private void OnSampleChanged(string value)
    {
        _selectedSampleKey = value;

        if (SampleMarkdownContent.IsDataOption(value))
        {
            var fileName = SampleMarkdownContent.TryGetDataFileName(value, out var name) ? name : value;
            var markdown = SampleMarkdownContent.ReadDataFile(Env.ContentRootPath, value);
            SyncLoadedDocument(fileName, markdown);
        }
        else
        {
            var sample = SampleMarkdownContent.GetByKey(value);
            SyncLoadedDocument($"{sample.Key}.md", sample.Markdown);
        }
    }

    private async Task OnUploadedMarkdownChanged(IBrowserFile? file)
    {
        if (file is null)
        {
            return;
        }

        await using var stream = file.OpenReadStream(MaxUploadedMarkdownBytes);
        using var reader = new StreamReader(stream);
        var markdown = await reader.ReadToEndAsync();

        SyncLoadedDocument(file.Name, markdown);
        _isUploadDragging = false;
    }

    private void OnUploadDraggingChanged(bool isDragging)
    {
        _isUploadDragging = isDragging;
    }

    private Task OnWrappedSaveAsync(string fullMarkdown)
    {
        _lastSaved = fullMarkdown;
        return Task.CompletedTask;
    }

    private void ResetWrappedSample()
    {
        _wrappedTitle = _loadedTitle;
        _wrappedContent = _loadedContent;
        StateHasChanged();
    }

    private void SyncLoadedDocument(string title, string markdown)
    {
        _loadedTitle = title;
        _loadedContent = markdown;
        _wrappedTitle = title;
        _wrappedContent = markdown;
    }

    private string GetUploadButtonClass()
    {
        return _isUploadDragging
            ? "wrappedtoast-upload-button wrappedtoast-upload-button-dragging"
            : "wrappedtoast-upload-button";
    }
}
