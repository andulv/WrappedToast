@page "/"

<PageTitle>Toast UI Samples</PageTitle>

<div class="sample-stack">
    <section>
        <h1>Toast UI editor and viewer samples</h1>
        <p>
            This sample app demonstrates usage of ASP.NET Blazor components <code>ToastUIEditor</code> and <code>ToastUIEditorViewer</code>.
        </p>
        <p>
            <code>ToastUIEditor</code> and <code>ToastUIEditorViewer</code> are thin wrappers around the corresponding components in JavaScript library <a href="https://ui.toast.com/tui-editor" target="_blank">Toast UI Editor</a>.
        </p>
    </section>

    <div class="sample-grid">
        <a class="sample-card" href="editor">
            <h2>Editor sample</h2>
            <p>Interactive editor surface with markdown and HTML readback.</p>
        </a>

        <a class="sample-card" href="viewer">
            <h2>Viewer sample</h2>
            <p>Viewer surface driven by markdown input and sample presets.</p>
        </a>
    </div>
</div>
