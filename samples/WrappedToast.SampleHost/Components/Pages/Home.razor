@page "/"

<PageTitle>Home</PageTitle>

<MudStack Spacing="4" Class="overflow-auto mud-height-full" Style="min-height:0;">
    <MudPaper Class="pa-6">
        <MudText Typo="Typo.h3" GutterBottom="true">WrappedToast</MudText>
        <MudText Typo="Typo.body1" GutterBottom="true">
            WrappedToast is a MudBlazor-friendly markdown editor and viewer wrapper built on TOAST UI Editor,
            with optional front matter support for application-style editing surfaces.
        </MudText>
        <MudText Typo="Typo.body1" GutterBottom="true">
            This sample host exists to show direct usage patterns for full-height editors and viewers, plus a
            combined page that exercises the reusable <code>WrappedToast</code> component end to end.
        </MudText>
    </MudPaper>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-6 mud-height-full">
                <MudText Typo="Typo.h5" GutterBottom="true">Quick Setup</MudText>
                <MudText Typo="Typo.body2" GutterBottom="true">
                    Register MudBlazor services in the host application.
                </MudText>
                <div class="home-code-block">
                    <pre><code>builder.Services.AddMudServices();</code></pre>
                </div>
                <MudText Typo="Typo.body2" Class="mt-4" GutterBottom="true">
                    Include the providers in your interactive layout tree.
                </MudText>
                <div class="home-code-block">
                    <pre><code>&lt;MudThemeProvider /&gt;
&lt;MudPopoverProvider /&gt;
&lt;MudDialogProvider /&gt;
&lt;MudSnackbarProvider /&gt;</code></pre>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-6 mud-height-full">
                <MudText Typo="Typo.h5" GutterBottom="true">Component Usage</MudText>
                <MudText Typo="Typo.body2" GutterBottom="true">
                    Render the higher-level component when you want a markdown workspace with save handling.
                </MudText>
                <div class="home-code-block">
                    <pre><code>@@using WrappedToast

&lt;WrappedToast Title="sample.md"
              Content="@@Markdown"
              OnSave="OnSaveAsync" /&gt;</code></pre>
                </div>
                <MudText Typo="Typo.body2" Class="mt-4" GutterBottom="true">
                    Or use the lower-level editor/viewer components directly when you only need one surface.
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Class="pa-6">
        <MudText Typo="Typo.h5" GutterBottom="true">Sample Pages</MudText>
        <MudText Typo="Typo.body2" GutterBottom="true">
            Use these pages to compare how the editor, viewer, and wrapper behave in different layout scenarios.
        </MudText>

        <MudStack Spacing="3">
            <MudPaper Outlined="true" Class="pa-4">
                <MudLink Href="/dual-sample">Dual Sample</MudLink>
                <MudText Typo="Typo.body2">Editor, viewer, and WrappedToast together on one page for side-by-side testing.</MudText>
            </MudPaper>
            <MudPaper Outlined="true" Class="pa-4">
                <MudLink Href="/editor-full-size">Full Height Editor</MudLink>
                <MudText Typo="Typo.body2">Editor only, filling the available application space.</MudText>
            </MudPaper>
            <MudPaper Outlined="true" Class="pa-4">
                <MudLink Href="/viewer-full-size">Full Height Viewer</MudLink>
                <MudText Typo="Typo.body2">Viewer only, using the same bounded workspace pattern.</MudText>
            </MudPaper>
            <MudPaper Outlined="true" Class="pa-4">
                <MudLink Href="/split-full-size">Split Editor And Viewer</MudLink>
                <MudText Typo="Typo.body2">Editor and viewer side by side in a full-height split workspace.</MudText>
            </MudPaper>
        </MudStack>
    </MudPaper>
</MudStack>
