@inherits ToastUIEditorCore

<div @ref="ElementRef" style="@InitialStyle"></div>

@code {
    protected override string JsModulePath => "./_content/WrappedToast/ToastUIEditor.razor.js";

    /// <summary>Get the current markdown text from the editor.</summary>
    public async Task<string> GetMarkdownAsync()
    {
        if (_module is null) return string.Empty;
        return await _module.InvokeAsync<string>("getMarkdown", new object?[] { ElementRef });
    }
}
