@inherits ComponentBase

<div class="wrapped-toast-shell d-flex flex-column flex-1 gap-2 mud-width-full">
    <MudStack Row="true" AlignItems="AlignItems.Stretch" Justify="Justify.SpaceBetween" Class="flex-none">
        @if (ShowTitle && !string.IsNullOrWhiteSpace(Title))
        {
            <MudText Typo="Typo.h6">@Title</MudText>
        }
        else
        {
            <span></span>
        }
        @if (_currentContent != null)
        {
            <MudStack Row="true" Spacing="1">
                @if (_isEditing)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Save"
                               OnClick="SaveAsync"
                               Disabled="_isSaving">
                        Save
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Cancel"
                               OnClick="ExitEditMode"
                               Disabled="_isSaving">
                        Cancel
                    </MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Edit"
                               OnClick="EnterEditMode">
                        Edit
                    </MudButton>
                    @ToolbarExtras
                }
            </MudStack>
        }
    </MudStack>

    @if (_currentContent?.FrontMatterRows.Count > 0)
    {
        <MudExpansionPanels Dense="true" Elevation="0" Gutters="false" Outlined="true" Class="flex-none">
            <MudExpansionPanel Dense="true" Gutters="false" Text="@($"Frontmatter ({_currentContent.FrontMatterRows.Count})")">
                <table class="frontmatter-table">
                    <tbody>
                        @foreach (var row in _currentContent.FrontMatterRows)
                        {
                            <tr class="@(row.IsSection ? "frontmatter-section-row" : null)">
                                <td class="@GetFrontMatterKeyClass(row.Level)">@row.Key</td>
                                <td class="frontmatter-value">@row.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </MudExpansionPanel>
        </MudExpansionPanels>
    }

    <div class="flex-1 overflow-hidden mud-width-full" style="min-width:0;min-height:0;">
        <ToastUIEditor @ref="_editor"
                       LoadAssets="LoadAssets"
                       InitialStyle="display: none; width:100%; height:100%; overflow:auto;"
                       Options="EditorOptions" />
        <ToastUIEditorViewer @ref="_viewer"
                             LoadAssets="false"
                             InitialStyle="display: block; width:100%; height:100%; overflow:auto;"
                             Options="ViewerOptions" />
    </div>
</div>
