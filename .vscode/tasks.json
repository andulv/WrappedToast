{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build: WrappedToast",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/WrappedToast/WrappedToast.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "build: SampleHost",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/samples/WrappedToast.SampleHost/WrappedToast.SampleHost.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile",
      "group": "build",
      "dependsOn": "build: WrappedToast"
    },
    {
      "label": "build: ToastUIEditorAndViewerSamples",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/samples/ToastUIEditorAndViewerSamples/ToastUIEditorAndViewerSamples.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile",
      "group": "build",
      "dependsOn": "build: WrappedToast"
    }
  ]
}
